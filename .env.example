# Flare error tracking (produzione)
FLARE_KEY=

# Feature flags
FEATURE_BETA_TRAINERS=
FEATURE_GROUP_CLASSES=false

# Feedback in-app
FEEDBACK_EMAIL=feedback@iron-gym.local

